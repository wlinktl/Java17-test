    "@angular/cli": "18.2.8",
    "@angular/compiler-cli": "18.2.8",
    "@angular/language-service": "18.2.8",
    "@ckeditor/ckeditor5-angular": "~10.0.0",
    "@types/echarts": "4.9.10",
    "@types/jasmine": "3.6.0",
    "@types/jasminewd2": "2.0.3",
    "@types/moment-timezone": "0.5.13",
    "@types/node": "12.11.1",
    "@types/sockjs-client": "1.1.1",
    "@types/stompjs": "2.3.4",
